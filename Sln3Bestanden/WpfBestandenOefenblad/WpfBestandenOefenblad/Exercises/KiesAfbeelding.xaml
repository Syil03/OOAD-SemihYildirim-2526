<Page x:Class="WpfBestandenOefenblad.Exercises.KiesAfbeelding"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfBestandenOefenblad.Exercises"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="KiesAfbeelding">

    <Grid Background="#eeeeee">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="300"/>
        </Grid.RowDefinitions>
        <Frame x:Name="fraAssignment" Grid.Row="0" Grid.Column="0" />
        <Border Background="White" Grid.Row="1">

            <StackPanel Background="#e6f2ff" Margin="10">
                <Button x:Name="btnKies" Content="Kies afbeelding..." 
                        HorizontalAlignment="Left" Padding="8,4" Margin="10,10,10,0" 
                        Click="BtnKies_Click"/>

                <TextBlock x:Name="txtBestandsnaam" FontStyle="Italic" Margin="10,5,10,10"/>

                <Image x:Name="imgAfbeelding" Height="200" Stretch="Uniform"/>
            </StackPanel>

        </Border>
    </Grid>
</Page>
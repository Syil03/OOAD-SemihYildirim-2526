<Page x:Class="WpfBestandenOefenblad.Exercises.LeesCsv"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfBestandenOefenblad.Exercises"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LeesCsv">

    <Grid Background="#eeeeee">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="320"/>
        </Grid.RowDefinitions>
        <Frame x:Name="fraAssignment" Grid.Row="0" Grid.Column="0" />
        <Border Background="White" Grid.Row="1">

            <Grid Margin="20" Background="#e6f2ff" MaxWidth="600">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button x:Name="btnLaad" Content="Laad verkoopcijfers" Grid.Row="0" 
                        Margin="10" Padding="8,4" HorizontalAlignment="Left" Click="BtnLaad_Click"/>

                <ListBox x:Name="lstVerkoop" Grid.Row="1" Margin="10,0,10,10"/>

                <TextBlock x:Name="txtTotaal" Grid.Row="2" Margin="10" 
                           FontWeight="Bold" FontSize="14" Text="Totaal verkoopbedrag: €0,00"/>
            </Grid>

        </Border>
    </Grid>
</Page>
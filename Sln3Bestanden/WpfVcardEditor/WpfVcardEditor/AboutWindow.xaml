        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About vCard Editor"
        Width="300" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel>
        <Image x:Name="imgLogo" Source="img/odisee.png" HorizontalAlignment="Center" Height="150" Margin="10" VerticalAlignment="Top" Width="250"/>
        <TextBlock HorizontalAlignment="Center" TextAlignment="Center" LineHeight="25" TextWrapping="Wrap" Margin="10"><Bold>Gemaakt door:</Bold> Semih Yildirim<LineBreak/><Bold>Vak:</Bold> OO Application Development<LineBreak/><Bold>Academiejaar:</Bold> 2025 - 2026</TextBlock>
        <Button x:Name="btnSluiten" Content="SLUITEN" HorizontalAlignment="Center" Margin="10" VerticalAlignment="Top" Padding="9,5" Click="Sluiten_Click"/>
    </StackPanel>
</Window>

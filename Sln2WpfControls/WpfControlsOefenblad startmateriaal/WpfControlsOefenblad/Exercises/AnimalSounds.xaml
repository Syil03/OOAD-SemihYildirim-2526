<Page x:Class="WpfControlsOefenblad.Exercises.AnimalSounds"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfControlsOefenblad.Exercises"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MatchImages">

    <Grid Background="#eeeeee">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="280"/>
        </Grid.RowDefinitions>

        <Frame x:Name="fraAssignment" Grid.Row="0" />
        <Border Background="White" Grid.Row="1">
            <!-- HIERONDER BEGINT XAML VAN DE OEFENING -->
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                <Image Source="/Exercises/Images/cat.png" Tag="cat.wav" Width="100" Height="100" Margin="10" MouseEnter="Image_MouseEnter" />
                <Image Source="/Exercises/Images/chicken.png" Tag="chicken.wav" Width="100" Height="100" Margin="10" MouseEnter="Image_MouseEnter" />
                <Image Source="/Exercises/Images/cow.png" Tag="cow.wav" Width="100" Height="100" Margin="10" MouseEnter="Image_MouseEnter" />
                <Image Source="/Exercises/Images/horse.png" Tag="horse.wav" Width="100" Height="100" Margin="10" MouseEnter="Image_MouseEnter" />
            </WrapPanel>

        </Border>
    </Grid>
</Page>
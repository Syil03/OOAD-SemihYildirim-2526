<Page x:Class="WpfControlsOefenblad.Exercises.LanguageSelector"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfControlsOefenblad.Exercises"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LanguageSelector">

    <Grid Background="#eeeeee">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>
        <Frame x:Name="fraAssignment" Grid.Row="0" />
        <Border Background="White" Grid.Row="1">

            <StackPanel Margin="20" HorizontalAlignment="Left" VerticalAlignment="Top">
                <ComboBox x:Name="cmbLanguages" Width="200" Padding="5" SelectionChanged="cmbLanguages_SelectionChanged">
                    <ComboBoxItem Content="Kies je taal..." IsSelected="True" />
                </ComboBox>

                <TextBlock x:Name="txtGreeting" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,0" />
            </StackPanel>

        </Border>
    </Grid>
</Page>
